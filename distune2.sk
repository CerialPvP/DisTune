options:
	botfight: "false"

	token: "no token for you L"
	bot: "DisTune"
	botName: DisTune
	p: $
	OwnerID: 702044939520835587
	abc: "a", "b", "c", "d", "e", "f", "g", "h", "i", "j", "k", "l", "m", "n", "o", "p", "q", "r", "s", "t", "u", "v", "w", "x", "y" or "z" 

	# footer
	footerText: "DisTune - A powerful Discord bot of your dreams."
	icon: "https://cdn.discordapp.com/attachments/809401069489750057/947037864120680458/distune-new.png"

	# yaml
	path: "plugins/DisTune/favorites.yml"

	# colors
	red: color from rgb 255, 0, 0
	blue: color from rgb 0, 0, 255
	green: color from rgb 0, 255, 0
	yellow: color from rgb 221, 255, 0
	orange: color from rgb 255, 179, 0
	aqua: color from rgb 0, 255, 251
	cyan: color from rgb 31, 145, 144
	black: color from rgb 0, 0, 0
	gray: color from rgb 28, 27, 27
	purple: color from rgb 54, 64, 246
	
	# discord api shit
	url: https://discord.com/api/v10/

on load:
	set {_token} to yml value "bot.token" from file "plugins/DisTune/important.yml"
	login to {_token} with name {@bot}
	set online status of bot {@bot} to online
	wait 2 seconds
	set {_size} to size of guilds of bot named {@bot}
	set presence of bot named {@bot} to playing "music in %{_size}% servers! | {@p}help"

on unload:
	set online status of bot {@bot} to do not disturb
	set presence of bot named {@bot} to playing "Reloading..."

