						set author icon of the embed to {@icon}
						set title of the embed to "Searching..."
						set description of the embed to "I am searching for **%arg 1%** on YouTube!"
						set color of the embed to {@yellow}
					reply with last made embed with event-bot and store it in {_msg}
					if {_r::*} is not set:
						make embed:
							set author of the embed to "Play"
							set author icon of the embed to {@icon}
							set title of the embed to "No results!"
							set description of the embed to "I can't find **%arg 1%** in YouTube! Try to provide a YouTube URL."
							set color of the embed to {@red}
						edit {_msg} to show last made embed
					
					else:
						set {_vc} to voice channel of event-member
