function noperm(p: text, id: integer):
	make embed:
		set title of the embed to "Lacking permissions!"
		set description of the embed to "You or your role is lacking the permission **%{_p}%**."
		set color of the embed to green
		set footer of the embed to {@footerText}
		set footer icon of the embed to {@icon}
		set timestamp of the embed to now
	send embed to text channel with id "%{_id}%" with bot named {@bot}

function checkCerial(id: integer) :: boolean:
	if {_id} = "702044939520835587":
		return true
	
	else:
		return false

function checkDev(id: integer) :: boolean:
	if {_id} = "":
		return true
	
	else:
		return false

discord command {@p}addevalblacklist [<string>]:
	trigger:
		if discord id of event-member = "702044939520835587":
			if arg 1 is set:
				add arg 1 to {blacklist.Eval::*}
				reply to event-message with "Added **%arg 1%** to eval blacklist. Anyone can't type anything involved with that."
				stop

discord command eval [<string>]:
	prefixes: {@p}
	category: other
	description: Evaluates Skript code.
	trigger:
		delete {_err::*}
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		#if discord id of event-channel = "922539550008541193":
		if arg 1 is set:
			# > We set a line number to every lines
			# > *huh, it could be easier and faster through stream but whatever*
			set {_code} to arg-1
			set {_finalcode} to ""
			set {_i} to 1
			loop split {_code} at nl:
				set {_finalcode} to "%{_finalcode}%%nl%%{_i}% | %loop-value%"
			add 1 to {_i}
			set {_code} to {_finalcode}

			# destroy event-message
			# > This is as you like ^
			make embed:
				set author of embed to "Code of %event-member%:"
				set author icon of embed to avatar of event-member
				set color of embed to yellow
				set description of embed to "__Your current code:__```applescript%nl%%{_code}%%nl%```%nl%__Parser Errors:__%nl%```Under execution ...```"
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
			set {_last} to last embed
			reply to event-message using last made embed with mention true with event-bot and store it in {_msg}

			wait 1 second
			if discord id of event-member = "702044939520835587" or "410781931727486976":
				if arg 1 contains "upload file ""plugins/DisTune/important.yml""", "upload file ""plugins/Skript/scripts/distune2.sk""", "upload file ""plugins\DisTune\important.yml""" or "upload file ""plugins\Skript\scripts\distune2.sk""":
					add "This is a critical file which is not allowed to be leaked!" to {_err::*}
				#if arg 1 contains "to console":
					#replace all "send " and " to console" in {_s} with ""
					#send "[Sent by DisTune eval] %{_s}%" to console
				else:
					eval arg-1 and store the errors in {_err::*}
				
			else:
				eval without executing arg-1 and store the errors in {_err::*}

			# > Don't ask me why I need to do something like that, is empty condition doesn't work here lmao
			if "%{_err::1}%" contains "<none>":
				set {_result} to "No error found!"
				if discord id of event-member = "702044939520835587" or "410781931727486976":
					set {_result} to "%{_result}% The code has been executed."
					
				else:
					set {_result} to "%{_result}% The code didn't execute since you're not Cerial or Emirhan."
				set embed color of {_last} to lime
			else:
				set {_result} to join {_err::*} with nl
				set embed color of {_last} to red
			set embed description of {_last} to "__Your current code:__```applescript%nl%%{_code}%%nl%```%nl%__Parser Errors (%size of {_err::*}%):__%nl%```%{_result}%```%nl%"
			edit {_msg} to show {_last}
				
		else:
			make embed:
				set author of the embed to "Eval Command"
				set author icon of the embed to {@icon}
				set title of the embed to "Eval info:"
				set description of the embed to "This command evaluates Skript code.%nl%Basically, you type a few lines of Skript code, then I will parse your code, and I will return errors if there are any.%nl%Only the owner gets the result of the command."
				set color of the embed to color from rgb 255, 0, 0
				set timestamp of the embed to now
				set the footer of embed to {@footerText}
				set the footer icon of embed to {@icon}
			reply to event-message using last made embed with mention true with event-bot
		

discord command play [<string>]:
	prefixes: {@p}
	category: music
	description: Plays music in a user's VC.
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		#if discord id of event-guild != "919252887694110740":
		#	reply to event-message with "Sorry, this command is temporarely not available to all guilds. There might be a new feature coming soon!" with event-bot
		#	stop
		if checkDistuneBan(event-guild) = true:
			reply to event-message with "This server is DisTune banned! The owner (<@%discord id of owner of event-guild%>) needs to appeal the server ban!"
			stop
		set {_b} to self member of event-bot in event-guild
		if voice channel of event-member is not set:
			make embed:
				set author of the embed to "Play"
				set author icon of the embed to {@icon}
				set title of the embed to "Your not in a VC!"
				set description of the embed to "To play music, you need to join a VC!"
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@red}
			reply to event-message with last made embed with event-bot

		else:
			if arg 1 is set:
				if arg 1 contains "youtube.com" or "youtu.be":
					search in youtube for arg 1 and store it in {_r::*}
					if {_r::*} is not set:
						make embed:
							set author of the embed to "Play"
							set author icon of the embed to {@icon}
							set title of the embed to "Song unlisted / private!"
							set description of the embed to "The link you have gave me is either unlisted or private."
							set footer of the embed to {@footerText}
							set footer icon of the embed to {@icon}
							set color of the embed to {@red}
						reply to event-message with last made embed with event-bot
						stop
					set {_thumb} to arg 1
					replace all "https://youtube.com/watch?v=" and "https://youtu.be/" in {_thumb} with ""
					set {_vc} to voice channel of event-member
					connect event-bot to {_vc}
					#play "https://cdn.discordapp.com/attachments/937063478324236358/937063501925609503/distune_songcountdown.mp3" in event-guild with bot {@bot}
					wait 0.1 seconds
					play {_r::1} in event-guild with event-bot
					make embed:
						set author of the embed to "Play"
						set author icon of the embed to {@icon}
						set title of the embed to "Playing music"
						set description of the embed to "I am now playing **%{_r::1}%**! Keep vibin'!"
						add field named "Track Duration" with value "%normalized track duration of {_r::1}%" to embed
						add field named "Song URL" with value "%url of {_r::1}%" to embed
						set image of the embed to track thumbnail of {_r::1}
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@green}
					reply to event-message with last made embed with event-bot
					stop
				
				if arg 1 contains "music.youtube.com":
					set {_play} to arg 1
					replace all "music." in {_play} with ""
					search in youtube for {_play} and store it in {_r::*}
					if {_r::*} is not set:
						make embed:
							set author of the embed to "Play"
							set author icon of the embed to {@icon}
							set title of the embed to "Song unlisted / private!"
							set description of the embed to "The link you have gave me is either unlisted or private."
							set footer of the embed to {@footerText}
							set footer icon of the embed to {@icon}
							set color of the embed to {@red}
						reply to event-message with last made embed with event-bot
						stop
					set {_thumb} to {_play}
					replace all "https://youtube.com/watch?v=" and "&feature=" in {_thumb} with ""
					set {_vc} to voice channel of event-member
					connect event-bot to {_vc}
					#play "https://cdn.discordapp.com/attachments/937063478324236358/937063501925609503/distune_songcountdown.mp3" in event-guild with bot {@bot}
					wait 0.1 seconds
					play {_r::1} in event-guild with event-bot
					make embed:
						set author of the embed to "Play"
						set author icon of the embed to {@icon}
						set title of the embed to "Playing music"
						set description of the embed to "I am now playing **%{_r::1}%**! Keep vibin'!"
						add field named "Track Duration" with value "%normalized track duration of {_r::1}%" to embed
						add field named "Song URL" with value "%url of {_r::1}%" to embed
						set image of the embed to track thumbnail of {_r::1}
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@green}
					reply to event-message with last made embed with event-bot
					stop

				else:
					search in youtube for arg 1 and store it in {_r::*}
					make embed:
						set author of the embed to "Play"
						set author icon of the embed to {@icon}
						set title of the embed to "Searching..."
						set description of the embed to "I am searching for **%arg 1%** on YouTube!"
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@yellow}
					reply to event-message with last made embed with event-bot and store it in {_msg}
					if {_r::*} is not set:
						make embed:
							set author of the embed to "Play"
							set author icon of the embed to {@icon}
							set title of the embed to "No results!"
							set description of the embed to "I can't find **%arg 1%** in YouTube! Try to provide a YouTube URL."
							set footer of the embed to {@footerText}
							set footer icon of the embed to {@icon}
							set color of the embed to {@red}
						edit {_msg} to show last made embed
					
					else:
						set {_vc} to voice channel of event-member
						connect event-bot to {_vc}
						force #play "https://cdn.discordapp.com/attachments/937063478324236358/937063501925609503/distune_songcountdown.mp3" in event-guild with bot {@bot}
						wait 0.1 seconds
						play {_r::1} in event-guild with event-bot
						set {_t} to {_r::1}
						make embed:
							set author of the embed to "Play"
							set author icon of the embed to {@icon}
							set title of the embed to "Playing music"
							set description of the embed to "I am now playing **%{_r::1}%**! Keep vibin'!%nl%This song isn't what you looked for? Try specifying a YouTube URL of the song you're looking for."
							add field named "Track Duration" with value "%normalized track duration of {_r::1}%" to embed
							add field named "Song URL" with value "%url of {_r::1}%" to embed
							set image of the embed to track thumbnail of {_t}
							set footer of the embed to {@footerText}
							set footer icon of the embed to {@icon}
							set color of the embed to {@green}
						edit {_msg} to show last made embed
			
			else:
				make embed:
					set author of the embed to "Play"
					set author icon of the embed to {@icon}
					set title of the embed to "No song name / URL!"
					set description of the embed to "Please specify a song name or YouTube / YouTube Music URL!"
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@red}
				reply to event-message with last made embed with event-bot


slash command play <string>:
	description: Plays music in a user's VC.
	guilds: 932659866110160936
	#bots: DisTune
	options:
		1:
			name: query
			description: Enter a YouTube URL or query to search.
	
	trigger:
		set {_b} to self member of event-bot in event-guild
		if voice channel of event-member is not set:
			make embed:
				set author of the embed to "Play"
				set author icon of the embed to {@icon}
				set title of the embed to "Your not in a VC!"
				set description of the embed to "To play music, you need to join a VC!"
				set color of the embed to {@red}
			reply with hidden last made embed with event-bot

		else:
			if arg 1 is set:
				if arg 1 contains "youtube.com" or "youtu.be":
					search in youtube for arg 1 and store it in {_r::*}
					if {_r::*} is not set:
						make embed:
							set author of the embed to "Play"
							set author icon of the embed to {@icon}
							set title of the embed to "Song unlisted / private!"
							set description of the embed to "The link you have gave me is either unlisted or private."
							set color of the embed to {@red}
						reply with hidden last made embed with event-bot
						stop
					set {_thumb} to arg 1
					replace all "https://youtube.com/watch?v=" and "https://youtu.be/" in {_thumb} with ""
					set {_vc} to voice channel of event-member
					connect event-bot to {_vc}
					#play "https://cdn.discordapp.com/attachments/937063478324236358/937063501925609503/distune_songcountdown.mp3" in event-guild with bot {@bot}
					wait 0.1 seconds
					play {_r::1} in event-guild with event-bot
