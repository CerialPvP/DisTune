import:
	org.bukkit.Bukkit
	java.lang.System

on load:
	{WAS_RELOADING} is set
	set {_v::*} to split {WAS_RELOADING} at "|"
	set {_last} to {_v::3} parsed as number
	retrieve message with id "%{_v::1}%" in (text channel with id "%{_v::2}%") and store it in {_msg}
	set {_current} to System.currentTimeMillis()
	set {_passed} to {_current} - {_last}
	edit {_msg} to show ":white_check_mark: **Reloaded successfully! `(%floor({_passed} / 1000)%s)`**"
	clear {WAS_RELOADING}

discord command {@p}reload:
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		if discord id of event-member = "702044939520835587":
			reply to event-message with ":warning: **Reloading...**" with event-bot and store it in {_msg}
			set {_current} to System.currentTimeMillis()
			set {WAS_RELOADING} to "%discord id of {_msg}%|%discord id of event-channel%|%{_current}%"
			#mass send " " 300 times
			console command "/sk reload distune2"
			stop
		
		else:
			reply to event-message with "You need to be Cerial to execute this!" with event-bot
			stop

function agreedToTOS(g: guild) :: boolean:
	set {_id} to discord id of {_g}
	if {accpetedTOS::%{_id}%} = true:
		return true
	else:
		return false

discord command {@p}addons:
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		if discord id of event-member = "702044939520835587":
			set {_addons::*} to addons list
			reply to event-message with "Addons: **%{_addons::*}%**" with event-bot
		
		else:
			reply to event-message with "You need to be Cerial to execute this!" with event-bot
			stop

expression total ram in (gigabytes|gb):
	get:
		set {_tram} to total ram
		set {_int} to first 1 characters of {_tram}
		set {_gbram} to 1024 * {_int}
		return {_gbram}

expression free ram in (gigabytes|gb):
	get:
		set {_tram} to free ram
		set {_int} to first 1 characters of {_tram}
		set {_gbram} to 1024 * {_int}
		return {_gbram}

expression max ram in (gigabytes|gb):
	get:
		set {_tram} to max ram
		set {_int} to first 1 characters of {_tram}
		set {_gbram} to 1024 * {_int}
		return {_gbram}

discord command hardwareinfo:
	prefixes: {@p}
	category: other
	description: View the hardware info of the PC that DisTune is running on.
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		set {_b} to "%System.getProperties()%"
		replace all "{" and "}" in {_b} with ""
		set {_s::*} to {_b} split at ", "
		set {_tram} to ((max ram)-(free ram))
		set {_tramd} to ({_tram}/(free ram)*100)
		# Replacers
		replace all "java.vendor.version=" in {_s::44} with ""
		replace all "os.name=" in {_s::12} with ""
		make embed:
			set author of the embed to "System"
			set author icon of the embed to {@icon}
			set title of the embed to "System Specs"
			add inline field named "Memory (RAM)" with value "Used: **%{_tram}%MB (%{_tramd}%%%)**%nl%Max: **%total ram%MB**" to embed
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@purple}
		reply to event-message with last made embed with event-bot
		wait 0.1 seconds
		delete {_tram}
		delete {_tramd}

on load:
	loop all guilds of bot {@bot}:
		add discord id of loop-value to {ids::*}
		add loop-value to {guilds::*}
		set {_size} to size of guilds of bot {@bot}

	set {_looped} to 0
	loop {_size} times:
		add 1 to {_looped}
		if file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" doesn't exist:
			create file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml"
			send "[Console] Made yml file for guild %{guilds::%{_looped}%}% [ID: %{ids::%{_looped}%}%]" to console
			set yml value "settings.stay" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "true"
			set yml value "settings.queuelimit" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "unlimited"
			set yml value "config.announcechannel" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "unknown"
			set yml value "effects.pitch" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "1"
	
	wait 0.1 seconds
	delete {_size}
	delete {_looped}
	delete {ids::*}
	delete {guilds::*}

on bot join guild:
	if file "plugins/DisTune/servers/%discord id of event-guild%.yml" doesn't exist:
		create file "plugins/DisTune/servers/%discord id of event-guild%.yml"
		send "[Console] Made yml file for guild **%event-guild%** [ID: %discord id of event-guild%]" to console
		set yml value "settings.stay" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "true"
		set yml value "settings.queuelimit" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "unlimited"
		set yml value "config.announcechannel" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "unknown"
		set yml value "effects.pitch" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "1"
		stop
	
	else:
		stop

on bot leave guild:
	if file "plugins/DisTune/servers/%discord id of event-guild%.yml" exists:
		delete file "plugins/DisTune/servers/%discord id of event-guild%.yml"
		send "[Console] Deleted yml file for guild **%event-guild%** [ID: %discord id of event-guild%]" to console
		stop
	
	else:
		stop

discord command {@p}ymltest:
	trigger:
		loop guilds of event-bot:
			add discord id of loop-value to {_ids::*}
		reply with "%{_ids::*}%"
		wait 1 tick
		delete {_ids::*}

on file clear:
	send "§cFile is (trying to) get wiped!" to console

on skript load:
	set {loaded} to now
	set {loaded.Unix} to unix timestamp of now
	set {loaded.Unix} to ceil({loaded.Unix})
	set {upTime.Counter} to true
	#set {calc} to difference between {loaded} and {unloaded}
	#if {calc} < 5 minutes:
	#	stop
	#else:
	set {upTime.s} to 0
	set {upTime.m} to 0
	set {upTime.h} to 0
	set {upTime.d} to 0

on skript unload:
	set {unloaded} to now
	set {unloaded.Unix} to unix timestamp of now
	set {unloaded.Unix} to ceil({unloaded.Unix})
	set {upTime.Counter} to false
	delete {upTime.s}
	delete {upTime.m}
	delete {upTime.h}
	delete {upTime.d}

every second:
	if {upTime.Counter} = true:
		add 1 to {upTime.s}
		if {upTime.s} = 60:
			set {upTime.s} to 0
			add 1 to {upTime.m}
		
		if {upTime.m} = 60:
			set {upTime.m} to 0
			add 1 to {upTime.h}
		
		if {upTime.h} = 24:
			set {upTime.h} to 0
			add 1 to {upTime.d}
	
	else:
		stop


discord command {@p}uptime:
	trigger:
		if {upTime.Counter} = true:
			make embed:
				set author of the embed to "Uptime"
				set author icon of the embed to {@icon}
				set title of the embed to "Uptime Counter"
				set description of the embed to "**DisTune** has been up for **%{upTime.d} ? 0%** days, **%{upTime.h} ? 0%** hours, **%{upTime.m} ? 0%** minutes and **%{upTime.s} ? 0%** seconds.%nl%Last started up <t:%{loaded.Unix}%:R> (<t:%{loaded.Unix}%>, in your local time)%nl%Last shut down <t:%{unloaded.Unix}%:R> (<t:%{unloaded.Unix}%>, in your local time)"
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@purple}
			reply to event-message with last made embed with event-bot
				
		else:
			reply to event-message with "Sorry, the uptime counter isn't active :(" with event-bot

discord command {@p}reload:
	trigger:
		if discord id of event-member = "702044939520835587":
			reply with ":warning: **Reloading...**" and store it in {msg}
			set {_current} to System.currentTimeMillis()
			set {WAS_RELOADING} to "%discord id of {_msg}%|%discord id of event-channel%|%{_current}%"
			console command "/sk reload %script%"
			stop

on script load:
	{WAS_RELOADING} is set
	set {_v::*} to split {WAS_RELOADING} at "|"
	set {_last} to {_v::3} parsed as number
	retrieve message with id "%{_v::1}%" in (text channel with id "%{_v::2}%") and store it in {_msg}
	set {_current} to System.currentTimeMillis()
	set {_passed} to {_current} - {_last}
	edit {msg} to show ":white_check_mark: **Restarted successfully! `(%floor({_passed} / 1000)%s)`**"
	clear {WAS_RELOADING}

discord command {@p}restart:
	trigger:
		if discord id of event-member = "702044939520835587":
			reply to event-message with "Restarting in 3..." with event-bot
			wait 1 second
			reply with "2..."
			wait 1 second
			reply with "1..."
			wait 1 second
			reply with ":warning: **Restarting... (may take a while)**" and store it in {msg}
			wait 0.1 seconds
			set {_current} to System.currentTimeMillis()
			set {restart_WAS_RELOADING} to "%discord id of {_msg}%|%discord id of event-channel%|%{_current}%"
			restart server
			stop
		
		else:
			reply to event-message with "You need to be Cerial to execute this!" with event-bot
			stop


on skript load:
	{restart_WAS_RELOADING} is set
	set {_v::*} to split {restart_WAS_RELOADING} at "|"
	set {_last} to {_v::3} parsed as number
	retrieve message with id "%{_v::1}%" in (text channel with id "%{_v::2}%") and store it in {_msg}
	set {_current} to System.currentTimeMillis()
	set {_passed} to {_current} - {_last}
	edit {msg} to show ":white_check_mark: **Restarted successfully! `(%floor({_passed} / 1000)%s)`**"
	clear {restart_WAS_RELOADING}

discord command ping:
	prefixes: {@p}
	trigger:
		reply to event-message with "Pong! :ping_pong: The ping of DisTune is **%bot ping of event-bot%ms**!" with event-bot

discord command {@p}reloadyml:
	trigger:
		if discord id of event-member = "702044939520835587":
			loop all guilds of bot {@bot}:
				add discord id of loop-value to {ids::*}
				add loop-value to {guilds::*}
				set {_size} to size of guilds of bot {@bot}

			set {_looped} to 0
			loop {_size} times:
				add 1 to {_looped}
				send "[Console] Changing YAML values (executed by %event-user%)"
				set yml value "settings.stay" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "true"
				set yml value "settings.queuelimit" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "unlimited"
				set yml value "config.announcechannel" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "unknown"
				set yml value "config.prefix" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "{@p}"
				set yml value "effects.pitch" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "1"
			
			reply to event-message with "Reloaded all configs successfully!" with event-bot

discord command {@p}dev [<text>] [<integer>] [<text>]:
	trigger:
		if discord id of event-member = "702044939520835587" or "410781931727486976":
			if arg 1 = "updateyml.servers":
				loop all guilds of bot {@bot}:
					add discord id of loop-value to {ids::*}
					add loop-value to {guilds::*}
					set {_size} to size of guilds of bot {@bot}

				set {_looped} to 0
				loop {_size} times:
					add 1 to {_looped}
					send "[Console] Changing YAML values (executed by %event-user%)"
					set yml value "settings.stay" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "true"
					set yml value "settings.queuelimit" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "unlimited"
					set yml value "config.announcechannel" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "unknown"
					set yml value "config.prefix" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "{@p}"
					set yml value "effects.pitch" from file "plugins/DisTune/servers/%{ids::%{_looped}%}%.yml" to "1"
				
				reply to event-message with "Reloaded all configs successfully!" with event-bot

			if arg 1 = "music.force":
				if arg 2 is set:
					if arg 3 is set:
						stop queue in event-guild with event-bot
						search for arg 3 on youtube and store it in {_r::*}
						play {_r::1} in guild with id "%arg 2%" with event-bot
						reply to event-message with "song.force is a success" with event-bot
					
					else:
						reply to event-message with "error.nourl" with event-bot
				
				else:
					reply to event-message with "error.noguildid" with event-bot

on message receive:
	if author of event-message is not a bot:
		set {_m::*} to mentioned members of event-message
		set {_b} to self member of {@bot} in event-guild
		if {_m::*} contains {_b}:
			reply to event-message with "Hey! My prefix in this server is `{@p}`! All commands use that prefix!" with event-bot
			stop

discord command {@p}downloadfile [<text>]:
	trigger:
		if discord id of event-member = "702044939520835587" or "410781931727486976":
			if arg 1 is set:
				reply to event-message with "Downloading file **%arg 1%**..." with event-bot
				upload file "%arg 1%" to event-channel with event-bot
			
			else:
				reply to event-message with "Please set the full directory of the file. Exmaple: ""plugins/Skript/config.sk""."
				stop
		
		else:
			reply to event-message with "You need to be Cerial or Emir to use this command!"
			stop
	

discord command {@p}info [<text>]:
	aliases: information
	trigger:
		if arg 1 is not set:
			make embed:
				set author of the embed to "Information"
				set author icon of the embed to {@icon}
				set title of the embed to "DisTune information"
				set description of the embed to "DisTune was a little project made by Cerial, which actually turned out to be worked hard on.%nl%The bot is coded in [Skript](https://youtu.be/3QUPFxifJuQ?t=17) (click on Skript to learn more).%nl%The server is hosted 24/7 using a 2nd pc laying around running Ubuntu Server.%nl%Please enjoy using my bot.%nl%%nl%To get specific information, please make sure to include a topic:%nl%%nl%**ban** - DisTune server & user ban info"
				add field named "Total Servers I am in" with value "%size of guilds of event-bot% servers (view a list of them using `{@p}servers`.)" to embed
				set {_c} to size of all discord commands
				add field named "Total commands" with value "**%{_c}%** commands registered (view 'em using `$help`)" to embed
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@purple}
			reply to event-message with last made embed with event-bot
		
		if arg 1 = "ban":
			make embed:
				set author of the embed to "Information"
				set author icon of the embed to {@icon}
				set title of the embed to "DisTune Ban information"
				set description of the embed to "Now, DisTune has a few set of rules in place, just to keep stuff clean.%nl%DisTune will automatically monitor some commands to our monitoring system (use `$info monitor` for more info about that topic).%nl%Let's say we are monitoring the play command (we are btw), the moderation team receives all the info about the track; length, name, url, ect."
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@purple}
			reply to event-message with last made embed with event-bot

effect mass send %message% %integer% times to %channel% with %-bot%:
	trigger:
		loop expr-2 times:
			send "%expr-1%" to expr-3 with expr-4

function buttonDebug(c: string, b: string):
	send ":warning: __Debug__%nl%Button name: %{_b}%" to channel with id {_c} with bot {@bot}

discord command {@p}support:
	trigger:
		set {_row} to new buttons row
		add new button "support_appeal" with style primary with content "Appeal user/server ban" with emoji "hammer" to buttons of {_row}
		add new button "support_other" with style primary with content "Other" with emoji "flushed" to buttons of {_row}
		make embed:
			set author of the embed to "Support"
			set author icon of the embed to {@icon}
			set title of the embed to "Select Topic"
			set description of the embed to "Please select from one of the options below.%nl%%betaCommand()%"
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@purple}
		reply to event-message with last made embed with event-bot with rows {_row}

on button click:
	#buttonDebug(discord id of event-channel, event-button)
	if event-button = "support_appeal":
		#defer the interaction
		reply with hidden "You've got mail!"
		make embed:
			set author of the embed to "Support"
			set author icon of the embed to {@icon}
			set title of the embed to "Support session started"
			set description of the embed to "You picked to get support for: **Appeals**"
			add field named "Info" with value "**User Appeals**%nl%If you are user banned (you can't use some features of DisTune), then you need to send the template below to me.%nl%You can check any info about your ban using `$status` in any Discord server with DisTune.%nl%**NOTE: Not following the template will result in an instant denial of the appeal.**%nl%```%nl%-USER BAN APPEAL- (INCLUDE THIS PART)%nl%%nl%Ban reason:%nl%Your ban ID:%nl%Why should you be unbanned:%nl%```%nl%**Server Appeals**%nl%If you are an owner of a Discord server which is DisTune banned, use this appeal.%nl%**NOTE 1: Not following the template will result in an instant denial of the appeal.**%nl%**NOTE 2: Please do not appeal for the owners, we can check the owner of the server you are trying to appeal for.**%nl%```%nl%-SERVER BAN APPEAL- (INCLUDE THIS PART)%nl%%nl%Server ID (right-click server > copy id):%nl%Ban reason:%nl%Server ban ID:%nl%Why should you be unbanned:%nl%```%nl%Happy appealing!" to embed
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@purple}
		send embed to event-user with bot {@bot}
		

discord command {@p}profile [<user>]:
	aliases: bal, balance
	trigger:
		if file "plugins/DisTune/userdata/%discord id of event-member%.yml" doesn't exist:
			make embed:
				set author of the embed to "Economy"
				set author icon of the embed to {@icon}
				set title of the embed to "Profile"
				set description of the embed to "Setting up your profile, please wait..."
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@yellow}
			reply to event-message with last made embed with event-bot and store it in {_pmsg}
			wait 5 second
			create file "plugins/DisTune/userdata/%discord id of event-member%.yml"
			set yml value "coins.pocket" from file "plugins/DisTune/userdata/%discord id of event-member%.yml" to 0
			set yml value "coins.bank" from file "plugins/DisTune/userdata/%discord id of event-member%.yml" to 0
			make embed:
				set author of the embed to "Economy"
				set author icon of the embed to {@icon}
				set title of the embed to "Profile"
				set description of the embed to "Profile made successfully!%nl%Note: If you want to request your data at anytime, execute `{@p}requestdata`."
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@green}
			edit {_pmsg} with last made embed
			stop
	

		else:
			if arg 1 is not set:
				set {_coins.p::%discord id of event-member%} to yml value "coins.pocket" from file "plugins/DisTune/userdata/%discord id of event-member%.yml"
				set {_coins.b::%discord id of event-member%} to yml value "coins.bank" from file "plugins/DisTune/userdata/%discord id of event-member%.yml"
				set {_lang::%discord id of event-member%} to yml value "user.language" from file "plugins/DisTune/userdata/%discord id of event-member%.yml"
				set {_badges::%discord id of event-member%::*} to yml list "badges" from file "plugins/DisTune/userdata/%discord id of event-member%.yml"
				if {_coins.p::%discord id of event-member%} is not set:
					set yml value "coins.pocket" from file "plugins/DisTune/userdata/%discord id of event-member%.yml" to 0
					reply to event-message with "I have encountered an error with your data file! It should work now!" with event-bot
				
				if {_coins.b::%discord id of event-member%} is not set:
					set yml value "coins.bank" from file "plugins/DisTune/userdata/%discord id of event-member%.yml" to 0
					reply to event-message with "I have encountered an error with your data file! It should work now!" with event-bot
				
				if {_badges::%discord id of event-member%::*} is not set:
					add "none" to yml list "badges" from file "plugins/DisTune/userdata/%discord id of event-member%.yml"
					reply to event-message with "I have encountered an error with your data file! It should work now!" with event-bot

				else if {_badges::%discord id of event-member%::*} is set:
					replace all ", " and "and " in {_badges::%discord id of event-member%::*} with ""

				make embed:
					set author of the embed to "Economy"
					set author icon of the embed to {@icon}
					set title of the embed to "Profile"
					set thumbnail of the embed to "%avatar of event-member%"
					set description of the embed to "This is your profile currently:"
					if {_badges::%discord id of event-member%::*} is set:
						add field named "Badges (use {@p}badges for more info about them)" with value "%{_badges::%discord id of event-member%::*}%" to embed
					add field named "TuneBucks in wallet :money_with_wings:" with value "**%{_coins.p::%discord id of event-member%}%** TuneBucks" to embed
					add field named "TuneBucks in bank :moneybag:" with value "**%{_coins.b::%discord id of event-member%}%** TuneBucks" to embed
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@purple}
				reply to event-message with last made embed with event-bot
			
			else:
				if file "plugins/DisTune/userdata/%discord id of arg 1%.yml" doesn't exist:
					make embed:
						set author of the embed to "Economy"
						set author icon of the embed to {@icon}
						set title of the embed to "Error!"
						set description of the embed to "%mention tag of arg 1% doesn't have a profile! They need to register one using `$profile`!"
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@purple}
					reply to event-message with last made embed with event-bot
				else:
					set {_coins.p::%discord id of arg 1%} to yml value "coins.pocket" from file "plugins/DisTune/userdata/%discord id of arg 1%.yml"
					set {_coins.b::%discord id of arg 1%} to yml value "coins.bank" from file "plugins/DisTune/userdata/%discord id of arg 1%.yml"
					make embed:
						set author of the embed to "Economy"
						set author icon of the embed to {@icon}
						set title of the embed to "Profile"
						set thumbnail of the embed to "%avatar of arg 1%"
						set description of the embed to "This is %mention tag of arg 1%'s profile currently:"
						add field named "TuneBucks in wallet :money_with_wings:" with value "**%{_coins.p::%discord id of arg 1%}%** TuneBucks" to embed
						add field named "TuneBucks in bank :moneybag:" with value "**%{_coins.b::%discord id of arg 1%}%** TuneBucks" to embed
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@purple}
					reply to event-message with last made embed with event-bot
			

		delete {_coins.p::%discord id of event-member%}
		delete {_coins.b::%discord id of event-member%}
		delete {_coins.p::%discord id of arg 1%}
		delete {_coins.b::%discord id of arg 1%}

discord command {@p}givebadge [<user>] [<text>] [<text>]:
	trigger:
		if discord id of event-member = "702044939520835587" or "410781931727486976":
			if arg 1 is not set:
				reply to event-message with "Usage: ```%nl%{@p}givebadge <user> <add|remove> <all|dev|mod|vip>%nl%```" with event-bot
				stop
			if arg 2 is not set:
				reply to event-message with "Usage: ```%nl%{@p}givebadge <user> <add|remove> <all|dev|mod|vip>%nl%```" with event-bot
				stop
			if arg 3 is not set:
				reply to event-message with "Usage: ```%nl%{@p}givebadge <user> <add|remove> <all|dev|mod|vip>%nl%```" with event-bot
				stop
			else:
				if file "plugins/DisTune/userdata/%discord id of arg 1%.yml" doesn't exist:
					reply to event-message with "%arg 1% doesn't have a profile yet!" with event-bot
					stop
				else:
					if arg 1 is set:
						if arg 2 = "remove":
							if arg 3 = "all":
								remove "<:distune_dev:944275107512205362>", "<:distune_mod:944275110087499836>" and "<:distune_vip:944276202473009202>" from yml list "badges" from file "plugins/DisTune/userdata/%discord id of arg 1%.yml"
								add "none" to yml list "badges" from file "plugins/DisTune/userdata/%discord id of arg 1%.yml"
								reply to event-message with "You have removed all of %mention tag of arg 1% **[%discord id of arg 1%]**'s badges." with event-bot
								send "All of your badges have been removed by %mention tag of event-member% **[%discord id of event-member%]**." to user with id "%discord id of arg 1%" with event-bot
							
							if arg 3 = "dev":
								remove "<:distune_dev:944275107512205362>" from yml list "badges" from file "plugins/DisTune/userdata/%discord id of arg 1%.yml"
								reply to event-message with "You have removed the **Bot Developer** badge." with event-bot
								send "Your **Bot Developer** badge has been removed by %mention tag of event-member% **[%discord id of event-member%]**." to user with id "%discord id of arg 1%" with event-bot
							
							if arg 3 = "mod":
								remove "<:distune_mod:944275110087499836>" from yml list "badges" from file "plugins/DisTune/userdata/%discord id of arg 1%.yml"
								reply to event-message with "You have removed the **Bot Moderator** badge." with event-bot
								send "Your **Bot Moderator** badge has been removed by %mention tag of event-member% **[%discord id of event-member%]**." to user with id "%discord id of arg 1%" with event-bot
							

							if arg 3 = "vip":
								remove "<:distune_vip:944276202473009202>" from  yml list "badges" from file "plugins/DisTune/userdata/%discord id of arg 1%.yml"
								reply to event-message with "You have removed the **Bot Developer** badge." with event-bot
								send "Your **VIP** badge has been removed by %mention tag of event-member% **[%discord id of event-member%]**." to user with id "%discord id of arg 1%" with event-bot
						
						if arg 2 = "add":
							if arg 3 = "all":
								remove "none" from yml list "badges" from file "plugins/DisTune/userdata/%discord id of arg 1%.yml"
								add "<:distune_dev:944275107512205362>", "<:distune_mod:944275110087499836>" and "<:distune_vip:944276202473009202>" from yml list "badges" from file "plugins/DisTune/userdata/%discord id of arg 1%.yml"
								reply to event-message with "You have added all badges to %mention tag of arg 1% **[%discord id of arg 1%]**'s profile." with event-bot
								send "All of the badges have been added to your profile by %mention tag of event-member% **[%discord id of event-member%]**." to user with id "%discord id of arg 1%" with event-bot
							
							if arg 3 = "dev":
								add "<:distune_dev:944275107512205362>" to yml list "badges" from file "plugins/DisTune/userdata/%discord id of arg 1%.yml"
								reply to event-message with "You have added the **Bot Developer** badge to %mention tag of arg 1% **[%discord id of arg 1%]**'s profile." with event-bot
								send "Your **Bot Developer** badge has been added by %mention tag of event-member% **[%discord id of event-member%]**." to user with id "%discord id of arg 1%" with event-bot
							
							if arg 3 = "mod":
								add "<:distune_mod:944275110087499836>" to yml list "badges" from file "plugins/DisTune/userdata/%discord id of arg 1%.yml"
								reply to event-message with "You have added the **Bot Moderator** badge to %mention tag of arg 1% **[%discord id of arg 1%]**'s profile." with event-bot
								send "Your **Bot Moderator** badge has been added by %mention tag of event-member% **[%discord id of event-member%]**." to user with id "%discord id of arg 1%" with event-bot
							

							if arg 3 = "vip":
								add "<:distune_vip:944276202473009202>" to yml list "badges" from file "plugins/DisTune/userdata/%discord id of arg 1%.yml"
								reply to event-message with "You have added the **VIP** badge to %mention tag of arg 1% **[%discord id of arg 1%]**'s profile." with event-bot
								send "Your **VIP** badge has been added by %mention tag of event-member% **[%discord id of event-member%]**." to user with id "%discord id of arg 1%" with event-bot
						

discord command {@p}givebucks [<text>] [<integer>] [<user>]:
	trigger:
		if discord id of event-member = "702044939520835587" or "410781931727486976":
			if arg 1 = "wallet":
				if arg 2 is set:
					if arg 3 is not set:
						set yml value "coins.pocket" from file "plugins/DisTune/userdata/%discord id of event-member%.yml" to arg 2
						reply to event-message with "Set your TuneBucks in your wallet to **%arg 2%**." with event-bot
						stop
					
					else:
						set yml value "coins.pocket" from file "plugins/DisTune/userdata/%discord id of arg 3%.yml" to arg 2
						reply to event-message with "Set %mention tag of arg 3%'s TuneBucks in their wallet to **%arg 2%**." with event-bot
						stop
				
				else:
					reply to event-message with "You need to set the amount of TuneBucks I need to add!" with event-bot
					stop
			
			if arg 1 = "bank":
				if arg 2 is set:
					if arg 3 is not set:
						set yml value "coins.bank" from file "plugins/DisTune/userdata/%discord id of event-member%.yml" to arg 2
						reply to event-message with "Set your TuneBucks in your bank to **%arg 2%**." with event-bot
						stop
					
					else:
						set yml value "coins.bank" from file "plugins/DisTune/userdata/%discord id of arg 3%.yml" to arg 2
						reply to event-message with "Set %mention tag of arg 3%'s TuneBucks in their bank to **%arg 2%**." with event-bot
						stop
				
				else:
					reply to event-message with "You need to set the amount of TuneBucks I need to add!" with event-bot
					stop
					
discord command {@p}changelanguage:
	aliases: שנהשפה
	trigger:
		set {_lang::%discord id of event-member%} to yml value "user.language" from file "plugins/DisTune/userdata/%discord id of event-member%.yml"
		reply to event-message with "%{_lang::%discord id of event-member%}%" with event-bot
		if {_lang::%discord id of event-member%} = "english":
			set yml value "user.language" from file "plugins/DisTune/userdata/%discord id of event-member%.yml" to "hebrew"
			reply to event-message with "שיניתי את השפה לעברית! כדי לשנות חזרה לאנגלית, כתבו `{@p}שנהשפה`." with event-bot
			stop
		
		if {_lang::%discord id of event-member%} = "hebrew"
			set yml value "user.language" from file "plugins/DisTune/userdata/%discord id of event-member%.yml" to "english"
			reply to event-message with "I changed the language to Englsh! To change it back to Hebrew, type `{@p}changelanguage`." with event-bot
			stop

discord command {@p}test:
	trigger:
		set {_t} to unix timestamp of now
		set {_t} to ceil({_t})
		reply to event-message with "<t:%{_t}%>"

discord command {@p}volume [<integer>]:
	trigger:
		if arg 1 is set:
			if arg 1 <= 100:
				set {_v} to arg 1 parsed as a number
				set track volume of event-guild to {_v}
				reply to event-message with "Set volume to **%arg 1%**%%." with event-bot
			
			else:
				reply to event-message with "The maximum volume is 100%%." with event-bot
				stop

discord command {@p}gayrate [<string>]:
	trigger:
		if arg 1 is not set:
			set {_u} to event-member
		else:
			set {_u} to arg 1
		set {_g} to random integer between 0 and 100
		make embed:
			set title of the embed to "Gay rate"
			set description of the embed to "Calculating, please wait..."
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@purple}
		reply to event-message with last made embed with event-bot and store it in {_e}
		wait 1 second
		if {_g} > 50:
			set {_msg} to "They might be onto something!"
		else if {_g} = 69:
			set {_msg} to "Nice number!"
		else:
			set {_msg} to "Good, you can be calm!"
		make embed:
			set title of the embed to "Gay rate"
			set description of the embed to "**%{_u}%** is **%{_g}%%%** gay :rainbow_flag:. %{_msg}%"
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@green}
		edit {_e} with last made embed

discord command {@p}yescat:
	trigger:
		make embed:
			set author of the embed to "Meme commands"
			set author icon of the embed to {@icon}
			set title of the embed to "Yes cat"
			set image of the embed to "https://c.tenor.com/dwHqzBdYWl0AAAAd/cat-yes.gif"
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@green}
		reply to event-message with last made embed with event-bot

function betaCommand() :: string:
	return "**NOTE: This command is currently in beta. Please report any issues using {@p}report.**"

discord command {@p}badges:
	trigger:
		make embed:
			set author of the embed to "Collectibles"
			set author icon of the embed to {@icon}
			set title of the embed to "Badges"
			set description of the embed to "Badges make your profile stand out."
			add field named "<:distune_dev:944275107512205362> - Developer" with value "This badge is given to the bot developers; Cerial and Emir.%nl%No one else can receive this badge." to embed
			add field named "<:distune_mod:944275110087499836> - Moderator" with value "This badge is given to the bot moderators.%nl%They are the one responsible for support and user and server bans." to embed
			add field named "<:distune_vip:944276202473009202> - VIP" with value "This badge is given to the people which are important to me.%nl%This would be people from my family, some online and all irl friends, ect." to embed
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@purple}
		reply to event-message with last made embed with event-bot



discord command {@p}userinfo [<user>]:
	trigger:
		if arg 1 is not set:
			set {_nick} to nickname of event-member
			if {_nick} = event-user:
				set {_nick} to "Not nicked!"
			
			if event-user is not a bot:
				set {_isbot} to "Not a bot!"
			else:
				set {_isbot} to "This is a bot!"
			make embed:
				set author of the embed to "Information"
				set author icon of the embed to {@icon}
				set title of the embed to "User Info"
				add inline field named "Username & Tag" with value "%event-user%##%discriminator of event-user%" to embed
				add inline field named "User ID" with value "%discord id of event-user%" to embed
				add inline field named "Server Nickname" with value "%{_nick}%" to embed
				add inline field named "Bot Status" with value "%{_isbot}%" to embed
				add inline field named "Account Creation Date" with value "%creation date of event-member%" to embed
				add inline field named "Server join Date" with value "%join date of event-member%" to embed
				add inline field named "Roles (%size of roles of event-member%)" with value "%roles of event-member%" to embed
				add inline field named "Online Status" with value "%online status of event-user%" to embed
				set thumbnail of the embed to avatar of event-user
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@purple}
			reply to event-message with last made embed with event-bot
		
		else:
			set {_nick} to nickname of arg 1
			if {_nick} = arg 1:
				set {_nick} to "Not nicked!"
			
			else if {_nick} is not set:
				set {_nick} to "Not nicked!"
			
			if arg 1 is not a bot:
				set {_isbot} to "Not a bot!"
			else:
				set {_isbot} to "This is a bot!"
			make embed:
				set author of the embed to "Information"
				set author icon of the embed to {@icon}
				set title of the embed to "User Info"
				add inline field named "Username & Tag" with value "%arg 1%##%discriminator of arg 1%" to embed
				add inline field named "User ID" with value "%discord id of arg 1%" to embed
				add inline field named "Server Nickname" with value "%{_nick}%" to embed
				add inline field named "Bot Status" with value "%{_isbot}%" to embed
				add inline field named "Join Date" with value "%join date of arg 1%" to embed
				add inline field named "Roles (%size of roles of arg 1%)" with value "%roles of arg 1%" to embed
				add inline field named "Online Status" with value "%online status of arg 1%" to embed
				set thumbnail of the embed to avatar of arg 1
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@purple}
			reply to event-message with last made embed with event-bot

discord command {@p}manageapps [<string>] [<string>]:
	category: staff
	trigger:
		if event-member has permission (administrator):
			if arg 1 is not set:
				make embed:
					set author of the embed to "Staff Applications"
					set author icon of the embed to {@icon}
					set title of the embed to "Application commands"
					set description of the embed to "**<>** - important arguments, **[]** - optional arguments"
					add field named "{@p}manageapps create <application name>" with value "Creates a new application. Max of 10 questions." to embed
					add field named "{@p}manageapps list" with value "Lists all applications." to embed
					add field named "{@p}manageapps edit <application name>" with value "Edit the application. You can edit, delete or add questions and edit the application name." to embed
					add field named "{@p}manageapps delete <application name>" with value "Delete an application."  to embed
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@purple}
				reply to event-message with last made embed with event-bot
		
			if arg 1 = "create":
				if arg 2 is set:
					add "%arg 2%" to yml list "applications.list" from file "plugins/DisTune/servers/%discord id of event-guild%.yml"
					add "none" to yml list "applications.questions.%arg 2%" from file "plugins/DisTune/servers/%discord id of event-guild%.yml"
					make embed:
						set author of the embed to "Staff Applications"
						set author icon of the embed to {@icon}
						set title of the embed to "Application created!"
						set description of the embed to "You have made the application **%arg 2%**. Other users cannot apply with this application until you finish editing your questions."
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@green}
					reply to event-message with last made embed with event-bot
					
				else:
					make embed:
						set author of the embed to "Staff Applications"
						set author icon of the embed to {@icon}
						set title of the embed to "Error!"
						set description of the embed to "Please set a name for your application.%nl%Usage: ```%nl%{@p}manageapps create <application name>%nl%```"
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@red}
					reply to event-message with last made embed with event-bot
			
			if arg 1 = "list":
				set {_apps::%discord id of event-guild%::*} to yml list "applications.list" from file "plugins/DisTune/servers/%discord id of event-guild%.yml"
				if {_apps::%discord id of event-guild%::*} is not set:
					make embed:
						set author of the embed to "Staff Applications"
						set author icon of the embed to {@icon}
						set title of the embed to "Error!"
						set description of the embed to "**%event-guild%** has no staff applications.%nl%To make one, use: ```%nl%{@p}manageapps create <application name>%nl%```"
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@red}
					reply to event-message with last made embed with event-bot
					stop
				make embed:
					set author of the embed to "Staff Applications"
					set author icon of the embed to {@icon}
					set title of the embed to "All applications in %event-guild%"
					set description of the embed to "%{_apps::%discord id of event-guild%::*}%"
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@purple}
				reply to event-message with last made embed with event-bot

			if arg 1 = "edit":
				if arg 2 is set:
					set {_apps::%discord id of event-guild%::*} to yml list "applications.list" from file "plugins/DisTune/servers/%discord id of event-guild%.yml"
					if {_apps::%discord id of event-guild%::*} doesn't contain arg 2:
						make embed:
							set author of the embed to "Staff Applications"
							set author icon of the embed to {@icon}
							set title of the embed to "No application with that name!"
							set description of the embed to "An application named **%arg 2%** doesn't exist. Did you spell it correctly?"
							set footer of the embed to {@footerText}
							set footer icon of the embed to {@icon}
							set color of the embed to {@red}
						reply to event-message with last made embed with event-bot
						stop
					
					else if {applications.Channel::%discord id of event-member%} is set:
						make embed:
							set author of the embed to "Staff Applications"
							set author icon of the embed to {@icon}
							set title of the embed to "You are editing an application!"
							set description of the embed to "You already have an application editing channel! Please go to <##%{applications.Channel::%discord id of event-member%}%>, which is your application editing channel.%nl%If you would like to edit a different application, please type `exit editor` in the editing channel."
							set footer of the embed to {@footerText}
							set footer icon of the embed to {@icon}
							set color of the embed to {@red}
						reply to event-message with last made embed with event-bot
						stop

					set {applications.Editing::%discord id of event-member%} to arg 2
					set {question::%discord id of event-member%} to false
					make text channel named "%event-member%-edit-%arg 2%" in event-guild with event-bot and store it in {applications.ChannelS::%discord id of event-member%}
					loop all members of event-guild:
						revoke permission view channel to loop-value in channel {applications.ChannelS::%discord id of event-member%} with event-bot
					allow permission view channel to event-member in channel {applications.ChannelS::%discord id of event-member%} with event-bot
					set {applications.Channel::%discord id of event-member%} to discord id of {applications.ChannelS::%discord id of event-member%}
					send "%mention tag of event-member%" to channel with id {applications.Channel::%discord id of event-member%} with event-bot and store it in {_tmsg}
					wait 2 ticks
					make embed:
						set author of the embed to "Staff Applications"
						set author icon of the embed to {@icon}
						set title of the embed to "Edit chat commands"
						set description of the embed to "We implemented a fast way to edit your application.%nl%You can type the following keywords in this channel:"
						add field named "create new question" with value "This makes a new question." to embed
						add field named "edit question" with value "This edits an existing question." to embed
						add field named "delete question" with value "This deletes an existing question." to embed
						add field named "list questions" with value "This shows all of the questions in this application." to embed
						add field named "change application name" with value "This changes the current application's name." to embed
						add field named "exit editor" with value "This deletes the current channel." to embed
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@purple}
					send embed to channel with id {applications.Channel::%discord id of event-member%} with event-bot
					wait 2 ticks
					delete {applications.AllActions::%discord id of event-member%::*}
					set {applications.LatestAction::%discord id of event-member%} to "Didn't do anything so far."
					add {applications.LatestAction::%discord id of event-member%} to {applications.AllActions::%discord id of event-member%::*}
					make embed:
						set author of the embed to "Staff Applications"
						set author icon of the embed to {@icon}
						set title of the embed to "Latest actions"
						set description of the embed to "In this embed, you can see the latest change you made to the application.%nl%%nl%:inbox_tray: **__Input:__** ```%nl%None%nl%```%nl%:outbox_tray: **__Output:__** ```%nl%%{applications.LatestAction::%discord id of event-member%}%%nl%```%nl%:file_folder: **__All Actions:__** ```%nl%%join {applications.AllActions::%discord id of event-member%::*} with nl%%nl%```"
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@purple}
					send embed to channel with id {applications.Channel::%discord id of event-member%} with event-bot and store it in {applications.actionsEmbed::%discord id of event-member%}
					wait 2 ticks
					make embed:
						set author of the embed to "Staff Applications"
						set author icon of the embed to {@icon}
						set title of the embed to "Edit application"
						set description of the embed to "I have made a channel for you to edit the application.%nl%The channel is <##%{applications.Channel::%discord id of event-member%}%>."
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@purple}
					reply to event-message with last made embed with event-bot and store it in {appEditG::%discord id of event-member%}
		
		else:
			make embed:
				set author of the embed to "Staff Applications"
				set author icon of the embed to {@icon}
				set title of the embed to "Error!"
				set description of the embed to "You need **Administator** permission in your role. If ths is a mistake, please contact the owner of the server to give you perms.%nl%We are not resposible if they say no."
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@red}
			reply to event-message with last made embed with event-bot

function messageDebug(m: string):
	send "&b&lDEBUG: &f%{_m}%" to console

discord command {@p}exiteditor [<user>]:
	trigger:
		if discord id of event-member = "702044939520835587":
			destroy text channel with id {applications.Channel::%discord id of arg 1%}
			delete {applications.AllActions::%discord id of arg 1%::*}
			delete {applications.Channel::%discord id of arg 1%}
			delete {question::%discord id of arg 1%}
			delete {applications.LatestAction::%discord id of arg 1%}
			delete {applications.actionsEmbed::%discord id of arg 1%}
			make embed:
				set author of the embed to "Staff Applications"
				set author icon of the embed to {@icon}
				set title of the embed to "Destoyed session successfully!"
				set description of the embed to "I have successfully deleted the editor session."
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@green}
			reply to event-message with last made embed with event-bot
		
		else:
			reply to event-message with "You must be Cerial to execute this command!" with event-bot

on message receive:
	event-user is not a bot
	if discord id of event-channel = {applications.Channel::%discord id of event-member%}:
		#messageDebug("variable exists")
		set {_c} to content of event-message
		destroy event-message
		remove "Didn't do anything so far." from {applications.AllActions::%discord id of event-member%::*}
		#messageDebug("message = %{_c}%")
		if {question::%discord id of event-member%} = true:
			set {question::%discord id of event-member%} to false
			#messageDebug("new question is set")
			remove "none" from yml list "applications.questions.%{applications.Editing::%discord id of event-member%}%" from file "plugins/DisTune/servers/%discord id of event-guild%.yml"
			#messageDebug("removed none from the yml")
			add "%{_c}%" to yml list "applications.questions.%{applications.Editing::%discord id of event-member%}%" from file "plugins/DisTune/servers/%discord id of event-guild%.yml"
			set {_qlist::*} to yml list "applications.questions.%{applications.Editing::%discord id of event-member%}%" from file "plugins/DisTune/servers/%discord id of event-guild%.yml"
			set {_questions} to size of {_qlist::*}
			#messageDebug("added the question to the yml")
			set {applications.LatestAction::%discord id of event-member%} to "Made new question ""%{_c}%"" (%{_questions}%/10 questions)"
			#messageDebug("edited action")
			add {applications.LatestAction::%discord id of event-member%} to {applications.AllActions::%discord id of event-member%::*}
			make embed:
				set author of the embed to "Staff Applications"
				set author icon of the embed to {@icon}
				set title of the embed to "Latest actions"
				set description of the embed to "In this embed, you can see the latest change you made to the application.%nl%%nl%:inbox_tray: **__Input:__** ```%nl%%{_c}%%nl%```%nl%:outbox_tray: **__Output:__** ```%nl%%{applications.LatestAction::%discord id of event-member%}%%nl%```%nl%:file_folder: **__All Actions:__** ```%nl%%join {applications.AllActions::%discord id of event-member%::*} with nl%%nl%```"
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@purple}
			edit {applications.actionsEmbed::%discord id of event-member%} with last made embed
			#messageDebug("edited embed")
			stop

		else:
			#messageDebug("its not a question")
			if {_c} = "exit editor":
				remove "Didn't do anything so far." from {applications.AllActions::%discord id of event-member%::*}
				set {applications.LatestAction::%discord id of event-member%} to "Exiting editor, please wait..."
				add {applications.LatestAction::%discord id of event-member%} to {applications.AllActions::%discord id of event-member%::*}
				make embed:
					set author of the embed to "Staff Applications"
					set author icon of the embed to {@icon}
					set title of the embed to "Latest actions"
					set description of the embed to "In this embed, you can see the latest change you made to the application.%nl%%nl%:inbox_tray: **__Input:__** ```%nl%%{_c}%%nl%```%nl%:outbox_tray: **__Output:__** ```%nl%%{applications.LatestAction::%discord id of event-member%}%%nl%```%nl%:file_folder: **__All Actions:__** ```%nl%%join {applications.AllActions::%discord id of event-member%::*} with nl%%nl%```"
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@purple}
				edit {applications.actionsEmbed::%discord id of event-member%} with last made embed
				wait 3 second
				make embed:
					set author of the embed to "Staff Applications"
					set author icon of the embed to {@icon}
					set title of the embed to "Edit application"
					set description of the embed to "You have closed the editor!"
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@red}
				edit {appEditG::%discord id of event-member%} with last made embed
				destroy text channel with id {applications.Channel::%discord id of event-member%}
				delete {applications.AllActions::%discord id of event-member%::*}
				delete {applications.Channel::%discord id of event-member%}
				delete {question::%discord id of event-member%}
				delete {applications.LatestAction::%discord id of event-member%}
				delete {applications.actionsEmbed::%discord id of event-member%}

			if {_c} = "distune.appedit.exit /nowait":
				if discord id of event-member = "702044939520835587":
					destroy text channel with id {applications.Channel::%discord id of event-member%}
					delete {applications.AllActions::%discord id of event-member%::*}
					delete {applications.Channel::%discord id of event-member%}
					delete {question::%discord id of event-member%}
					delete {applications.LatestAction::%discord id of event-member%}
					delete {applications.actionsEmbed::%discord id of event-member%}
				
				else:
					set {applications.LatestAction::%discord id of event-member%} to "Sorry, the --nowait argument is for Cerial only."
					add {applications.LatestAction::%discord id of event-member%} to {applications.AllActions::%discord id of event-member%::*}
					make embed:
						set author of the embed to "Staff Applications"
						set author icon of the embed to {@icon}
						set title of the embed to "Latest actions"
						set description of the embed to "In this embed, you can see the latest change you made to the application.%nl%%nl%:inbox_tray: **__Input:__** ```%nl%%{_c}%%nl%```%nl%:outbox_tray: **__Output:__** ```%nl%%{applications.LatestAction::%discord id of event-member%}%%nl%```%nl%:file_folder: **__All Actions:__** ```%nl%%join {applications.AllActions::%discord id of event-member%::*} with nl%%nl%```"
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@purple}
					edit {applications.actionsEmbed::%discord id of event-member%} with last made embed
			
			if {_c} = "create new question":
				set {_qlist::*} to yml list "applications.questions.%{applications.Editing::%discord id of event-member%}%" from file "plugins/DisTune/servers/%discord id of event-guild%.yml"
				set {_questions} to size of {_qlist::*}
				#messageDebug("there are %{_questions}% questions right now")
				if {_questions} = 10:
					set {question::%discord id of event-member%} to false
					set {applications.LatestAction::%discord id of event-member%} to "Sorry, this application has reached a maximum of 10 questions!"
					make embed:
						set author of the embed to "Staff Applications"
						set author icon of the embed to {@icon}
						set title of the embed to "Latest actions"
						set description of the embed to "In this embed, you can see the latest change you made to the application.%nl%%nl%:inbox_tray: **__Input:__** ```%nl%%{_c}%%nl%```%nl%:outbox_tray: **__Output:__** ```%nl%%{applications.LatestAction::%discord id of event-member%}%%nl%```%nl%:file_folder: **__All Actions:__** ```%nl%%join {applications.AllActions::%discord id of event-member%::*} with nl%%nl%```"
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@purple}
					edit {applications.actionsEmbed::%discord id of event-member%} with last made embed
					stop
				else:
					set {question::%discord id of event-member%} to true
					set {applications.LatestAction::%discord id of event-member%} to "Please enter a question name below!"
					make embed:
						set author of the embed to "Staff Applications"
						set author icon of the embed to {@icon}
						set title of the embed to "Latest actions"
						set description of the embed to "In this embed, you can see the latest change you made to the application.%nl%%nl%:inbox_tray: **__Input:__** ```%nl%%{_c}%%nl%```%nl%:outbox_tray: **__Output:__** ```%nl%%{applications.LatestAction::%discord id of event-member%}%%nl%```%nl%:file_folder: **__All Actions:__** ```%nl%%join {applications.AllActions::%discord id of event-member%::*} with nl%%nl%```"
						set footer of the embed to {@footerText}
						set footer icon of the embed to {@icon}
						set color of the embed to {@purple}
					edit {applications.actionsEmbed::%discord id of event-member%} with last made embed
				
			if {_c} = "list questions":
				set {_qlist::*} to yml list "applications.questions.%{applications.Editing::%discord id of event-member%}%" from file "plugins/DisTune/servers/%discord id of event-guild%.yml"
				remove "Didn't do anything so far." from {applications.AllActions::%discord id of event-member%::*}
				set {applications.LatestAction::%discord id of event-member%} to "Listed all questions."
				add {applications.LatestAction::%discord id of event-member%} to {applications.AllActions::%discord id of event-member%::*}
				make embed:
					set author of the embed to "Staff Applications"
					set author icon of the embed to {@icon}
					set title of the embed to "Latest actions"
					set description of the embed to "In this embed, you can see the latest change you made to the application.%nl%%nl%:inbox_tray: **__Input:__** ```%nl%%{_c}%%nl%```%nl%:outbox_tray: **__Output:__** ```%nl%%{applications.LatestAction::%discord id of event-member%}%%nl%```%nl%:file_folder: **__All Actions:__** ```%nl%%join {applications.AllActions::%discord id of event-member%::*} with nl%%nl%```"
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@purple}
				edit {applications.actionsEmbed::%discord id of event-member%} with last made embed
				wait 0.1 seconds
				make embed:
					set author of the embed to "Staff Applications"
					set author icon of the embed to {@icon}
					set title of the embed to "Questions list"
					set description of the embed to "**Note: This embed deletes itself in 10 seconds.**%nl%```%nl%%join {_qlist::*} with nl%%nl%```"
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@purple}
				reply with last made embed and store it in {qlistEmbed::%discord id of event-member%}
				wait 10 seconds
				destroy {qlistEmbed::%discord id of event-member%}
				delete {qlistEmbed::%discord id of event-member%}

			else:
				remove "Didn't do anything so far." from {applications.AllActions::%discord id of event-member%::*}
				set {applications.LatestAction::%discord id of event-member%} to "Unknown command ""%{_c}%"". Check the message above for the commands list."
				add {applications.LatestAction::%discord id of event-member%} to {applications.AllActions::%discord id of event-member%::*}
				make embed:
					set author of the embed to "Staff Applications"
					set author icon of the embed to {@icon}
					set title of the embed to "Latest actions"
					set description of the embed to "In this embed, you can see the latest change you made to the application.%nl%%nl%:inbox_tray: **__Input:__** ```%nl%%{_c}%%nl%```%nl%:outbox_tray: **__Output:__** ```%nl%%{applications.LatestAction::%discord id of event-member%}%%nl%```%nl%:file_folder: **__All Actions:__** ```%nl%%join {applications.AllActions::%discord id of event-member%::*} with nl%%nl%```"
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@purple}
				edit {applications.actionsEmbed::%discord id of event-member%} with last made embed

discord command {@p}mclookup [<string>]:
	trigger:
		if arg 1 is set:
			set {_p} to arg 1 parsed as an offline player
			set {_u} to uuid of {_p}
			if {_u} is not set:
				make embed:
					set author of the embed to "Minecraft"
					set author icon of the embed to {@icon}
					set title of the embed to "Username doesn't exist!"
					set description of the embed to "The username **%arg 1%** doesn't exist. Try checking your spelling or checking a different username."
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@purple}
				reply to event-message with last made embed with event-bot
				stop
				
			make embed:
				set author of the embed to "Minecraft"
				set author icon of the embed to {@icon}
				set title of the embed to "User Lookup"
				set thumbnail of the embed to "https://minotar.net/armor/bust/%{_u}%/100.png"
				add field named "Username" with value "%{_p}%" to embed
				add field named "UUID" with value "%{_u}%" to embed
				add field named "Skin" with value "[Click me to download!](https://minotar.net/download/%{_u}%)" to embed
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@purple}
			reply to event-message with last made embed with event-bot


discord command {@p}roast:
	trigger:
		set {_r} to text from url "https://insult.mattbas.org/api/insult.txt"
		reply to event-message with "**NOTE: The roast might contain swear words and might be too harsh to view. Click the spoiler to proceed.**%nl%||%{_r}%||%nl%%nl%**Idea by Vian##7777**" with event-bot

discord command {@p}botperms:
	trigger:
		set {_b} to self member of event-bot in event-guild
		reply to event-message with "My permissions in **%event-guild%** are: **%permissions of {_b} in event-channel%**" with event-bot

discord command {@p}penis [<string>]:
	aliases: pp
	trigger:
		if arg 1 is not set:
			set {_u} to event-member
		else:
			set {_u} to arg 1
		set {_g::%discord id of event-member%} to random integer between 2 and 20
		if {_g::%discord id of event-member%} = {previouspp::%discord id of event-member%}:
			set {_g::%discord id of event-member%} to random integer between 2 and 20
		loop {_g::%discord id of event-member%} times:
			add "=" to {_pp1::%discord id of event-member%::*}
		set {_pp2::%discord id of event-member%::*} to join {_pp1::%discord id of event-member%::*} with "|"
		replace all "|" in {_pp2::%discord id of event-member%::*} with ""
		make embed:
			set title of the embed to "Penis size"
			set description of the embed to "Calculating, please wait..."
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@purple}
		reply to event-message with last made embed with event-bot and store it in {_e::%discord id of event-member%}
		wait 1 second
		make embed:
			set title of the embed to "Penis size"
			set description of the embed to "**%{_u}%**'s penis is **8%{_pp2::%discord id of event-member%::*}%D**"
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@green}
		edit {_e::%discord id of event-member%} with last made embed
		wait 0.1 seconds
		set {previouspp::%discord id of event-member%} to {_g}
		delete {_pp1::%discord id of event-member%::*}
		delete {_pp2::%discord id of event-member%::*}

discord command {@p}distuneban [<text>] [<string>]:
	trigger:
		if discord id of event-member = "702044939520835587":
			if arg 1 = "guild":
				stop current queue of event-guild
				disconnect bot of event-guild
				set {distuneBanned::%discord id of event-guild%} to true
				send "Your server, **%event-guild%** is DisTune banned. Please use `{@p}support` to appeal your server ban." to user with id "%discord id of owner of event-guild%" with event-bot
				reply to event-message with "DisTune banned **%event-guild%** [%discord id of event-guild%] successfully." with event-bot
				stop

function checkDistuneBan(g: guild) :: boolean:
	if {distuneBanned::%discord id of {_g}%} = false:
		return false
	else:
		return true

function resetStatus():
	set {_size} to size of guilds of bot named {@bot}
	set presence of bot named {@bot} to playing "music in %{_size}% servers! | {@p}help"

discord command {@p}setstatus [<string>] [<string>]:
	trigger:
		if arg 1 = "playing":
			if arg 2 is set:
				set presence of bot named {@bot} to playing "%arg 2% | {@p}help"
				reply to event-message with "Look at me!" with event-bot
				wait 10 seconds
				resetStatus()
			
		
		if arg 1 = "listening to":
			if arg 2 is set:
				set presence of bot named {@bot} to listening to "%arg 2% | {@p}help"
				reply to event-message with "Look at me!" with event-bot
				wait 10 seconds
				resetStatus()
		
		if arg 1 = "watching":
			if arg 2 is set:
				set presence of bot named {@bot} to watching "%arg 2% | {@p}help"
				reply to event-message with "Look at me!" with event-bot
				wait 10 seconds
				resetStatus()

discord command {@p}twitter:
	trigger:
		set {_row} to new buttons row
		add new link button with url "https://twitter.com/distune_bot" with style success with content "Go to Twitter" with emoji "twitter" to buttons of {_row}
		make embed:
			set author of the embed to "Twitter"
			set author icon of the embed to {@icon}
			set title of the embed to "My twitter!"
			set description of the embed to "To go to my twitter, you can either click on the button below to go to my page, or just search **@distune_bot** on Twitter."
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@purple}
		reply to event-message with last made embed with event-bot with rows {_row}

