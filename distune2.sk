						force #play "https://cdn.discordapp.com/attachments/937063478324236358/937063501925609503/distune_songcountdown.mp3" in event-guild with bot {@bot}
						wait 0.1 seconds
						play {_r::1} in event-guild with event-bot
						set {_t} to {_r::1}
						make embed:
							set author of the embed to "Play"
							set author icon of the embed to {@icon}
							set title of the embed to "Playing music"
							set description of the embed to "I am now playing **%{_r::1}%**! Keep vibin'!%nl%This song isn't what you looked for? Try specifying a YouTube URL of the song you're looking for."
							add field named "Track Duration" with value "%normalized track duration of {_r::1}%" to embed
							set image of the embed to track thumbnail of {_t}
							set color of the embed to {@green}
						edit {_msg} to show last made embed
			
			else:
