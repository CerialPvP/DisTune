					set title of the embed to "No song name / URL!"
					set description of the embed to "Please specify a song name or YouTube / YouTube Music URL!"
					set color of the embed to {@red}
				reply with last made embed with event-bot

discord command resume:
	prefixes: {@p}
	category: music
	description: Unpauses / Resumes the paused song.
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		resume in event-guild

on button click:
	if event-button = "queue":
		make embed:
			set author of the embed to "Server Queue"
			set author icon of the embed to {@icon}
			set title of the embed to "Queue"
			set {_size} to size of queue of event-guild
			set {_queue::*} to queue of event-guild
			set {_num} to -1
			loop 11 times:
				add 1 to {_num}
				if {_queue::%{_num}%} is set:
					add "##%{_num}%. **%{_queue::%{_num}%}%** **[%track duration of {_queue::%{_num}%}%]**%nl%" to {_songs::*}
			set description of the embed to join {_songs::*} with nl
			set color of the embed to {@purple}
		reply with hidden last made embed



discord command stop:
	prefixes: {@p}
	category: music
	description: Stops the current song you're listening to.
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		set {_bot} to self member of event-bot in event-guild
		if voice channel of {_bot} is set:
			stop current queue of event-guild
			disconnect bot of event-guild
			make embed:
				set author of the embed to "Play Command"
				set author icon of the embed to {@icon}
				set title of the embed to "Stopped Music"
				set description of the embed to "I have stopped the music in **%event-guild%**."
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to lime
			reply to event-message using last made embed with event-bot

discord command repeat:
	prefixes: {@p}
	category: music
	description: Repeats the current song you're listening to.
	aliases: loop
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		if bot is repeating in event-guild:
			set repeating state of event-guild to false
			make embed:
				set author of the embed to "Repeat / Loop"
				set author icon of the embed to {@icon}
				set title of the embed to "Looping is disabled!"
				set description of the embed to "I am no longer looping the same song in **%event-guild%**."
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to lime
			reply to event-message using last made embed with event-bot
		
		else:
			set repeating state of event-guild to true
			make embed:
				set author of the embed to "Repeat / Loop"
				set author icon of the embed to {@icon}
				set title of the embed to "Looping is enabled!"
				set description of the embed to "I am now looping the current song in **%event-guild%**."
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to lime
			reply to event-message using last made embed with event-bot

discord command {@p}skip:
	category: music
	description: Skips the current song that is playing.
	trigger:
		skip track of event-guild with event-bot
		make embed:
			set author of the embed to "Skip"
			set author icon of the embed to {@icon}
			set title of the embed to "Track skipped!"
			set description of the embed to "I am now playing the next song in queue."
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to lime
		reply to event-message using last made embed with event-bot

discord command {@p}fastforward [<integer>]:
	aliases: ff
	category: music
	description: (BROKEN) Fast forwards a song by a few seconds
	trigger:
		if arg 1 is set:
			set {_pp} to track position of track event-bot is playing in event-guild
			wait 0.1 seconds
			set {_s} to arg 1 parsed as a number
			set {_s} to ceil({_s})
			add {_s} seconds to track position of track event-bot is playing in event-guild
			wait 0.1 seconds
			set {_pp2} to track position of track event-bot is playing in event-guild
			make embed:
				set author of the embed to "Fast Forward"
				set author icon of the embed to {@icon}
				set title of the embed to "Track fast forwarded!"
				set description of the embed to "I have fast forwarded the track by **%arg 1%** seconds!"
				add field named "Old position" with value "%{_pp}%" to embed
				add field named "New position" with value "%{_pp2}%" to embed
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@green}
			reply to event-message using last made embed with event-bot

discord command {@p}queue:
	category: music
	description: Shows the queue of the server.
	trigger:
		if track event-bot is pSlaying in event-guild is set:
			set {_looped} to 0
			set {_q::*} to queue of event-guild
			add "Current Song: %track event-bot is playing in event-guild% [%normalized track duration of track event-bot is playing in event-guil%]%nl%" to {_qlist::*}
			loop 10 times:
				add 1 to {_looped}
				if {_q::%{looped}%} is set:
					add "##%{_looped}%: %{_q::%{_looped}%}% [%normalized track duration of {_q::%{_looped}%}%]" to {_qlist::*}
				else:
					stop loop
			make embed:
				set author of the embed to "Queue"
				set author icon of the embed to {@icon}
				set title of the embed to "Song list"
				set description of the embed to "Here is the queue: ```%nl%%join {_qlist::*} with nl%%nl%```"
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@purple}
			reply to event-message using last made embed with event-bot
		
		else:
			make embed:
				set author of the embed to "Queue"
				set author icon of the embed to {@icon}
				set title of the embed to "Error!"
				set description of the embed to "There are no songs in queue!"
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@red}
			reply to event-message using last made embed with event-bot

discord command {@p}shuffle:
	category: music
	description: Randomises the queue of the server.
	trigger:
		shuffle queue in event-guild with event-bot
		make embed:
			set author of the embed to "Shuffle"
			set author icon of the embed to {@icon}
			set title of the embed to "Queue shuffled!"
			set description of the embed to "All the songs are randomized. You can see the new order using `{@p}queue`."
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@green}
		reply to event-message using last made embed with event-bot

import:
	org.apache.commons.lang3.StringUtils

function reloadSimilarity():
	delete {similarity::*}
	loop all discord commands:
		add "%loop-value%" to {similarity::*}
		add loop-value's discord aliases to {similarity::*}

on load:
	reloadSimilarity()

on message receive:
	if event-user is not a discord bot:
		if "%event-message%" starts with "{@p}" or "{@p}":
			set {_split::*} to ("%event-message%") split at " "
			replace first "{@p}" with "" in {_split::1}
			"%{similarity::*}%" does not contain "%{_split::1}%"
			set {_best} to 0
			loop {similarity::*}:
				set {_n} to StringUtils.getJaroWinklerDistance(loop-value, "%{_split::1}%")*100
				if {_n} > {_best}:
					set {_best} to {_n}
					set {_best::cmd} to loop-value
			if {_best} >= 50:
				set {best::%discord id of event-member%}
				set {_row} to new buttons row
				add new disabled button "cmd_sim" with style secondary with content "Best match (%{_best}%%%): {@p}%{_best::cmd}%" with emoji "white_check_mark" to buttons of {_row}
				make embed:
					set author of the embed to "Command Similarities"
					set author icon of the embed to {@icon}
					set title of the embed to "Similar command!"
					set description of the embed to "That command doesn't exist.%nl%Although, I found a command which is similar to this: `{@p}%{_best::cmd}%`"
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@yellow}
				reply to event-message with last made embed with mention true with event-bot with rows {_row}

slash command effects <string> <string>:
	description: Plays music in a user's VC.
	guilds: 932659866110160936
	#bots: DisTune
	options:
		1:
			name: effectName
			description: The effect name.
		
		2:
			name: number
			description: The value of the effect.
	
	trigger:
		if arg 1 is not set:
			set {_p} to yml value "effects.pitch" from file "plugins/DisTune/servers/%discord id of event-guild%.yml"
			make embed:
				set author of the embed to "Music Effects"
				set author icon of the embed to {@icon}
				set title of the embed to "Active Effects"
				set description of the embed to ":deer: **Pitch** - %{_p}%"
				set color of the embed to {@yellow}
			reply with last made embed with event-bot
		
		if arg 1 = "pitch":
			if arg 2 is set:
				set yml value "effects.pitch" from file "plugins/DisTune/servers/%discord id of event-guild%.yml" to arg 2
				set {_p} to yml value "effects.pitch" from file "plugins/DisTune/servers/%discord id of event-guild%.yml"
				set audio pitch of event-guild to {_p}
				make embed:
					set author of the embed to "Music Effects"
					set author icon of the embed to {@icon}
					set title of the embed to "Changed pitch"
					set description of the embed to "I changed the pitch to `%arg 2%`!%nl%This will take a few seconds to change."
					set color of the embed to {@green}
				reply with last made embed with event-bot

discord command effects [<text>] [<string>]:
	prefixes: {@p}
	category: music
	description: Adds effects to the song.
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		if arg 1 is not set:
			set {_p} to yml value "effects.pitch" from file "plugins/DisTune/servers/%discord id of event-guild%.yml"
			make embed:
				set author of the embed to "Music Effects"
				set author icon of the embed to {@icon}
				set title of the embed to "Active Effects"
				set description of the embed to ":deer: **Pitch** - %{_p}%"
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@yellow}
			reply to event-message using last made embed with event-bot
		
		if arg 1 = "pitch":
			if arg 2 is set:
				set yml value "effects.pitch" from file "plugins/DisTune/servers/%discord id of event-guild%.yml" to arg 2
				set {_p} to yml value "effects.pitch" from file "plugins/DisTune/servers/%discord id of event-guild%.yml"
				set audio pitch of event-guild to {_p}
				make embed:
					set author of the embed to "Music Effects"
					set author icon of the embed to {@icon}
					set title of the embed to "Changed pitch"
					set description of the embed to "I changed the pitch to `%arg 2%`!%nl%This will take a few seconds to change."
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@green}
				reply to event-message using last made embed with event-bot
			
discord command invite:
	prefixes: {@p}
	category: other
	description: Sends a link to invite me!
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		set {_row} to new buttons row
		add new link button with url "https://discord.com/oauth2/authorize?client_id=919249309508206652&permissions=36759824&scope=bot" with style success with content "Invite DisTune!" with emoji ":link:" to buttons of {_row}
		add new link button with url "https://discord.gg/vpjefqnRYR" with style success with content "Support Server" with emoji ":link:" to buttons of {_row}
		make embed:
			set author of the embed to "Invite DisTune"
			set author icon of the embed to {@icon}
			set title of the embed to "Invite me!"
			set description of the embed to "To invite me, you can click on my profile and click **Add to server**, or click the button below.%nl%NOTE: If you want to add the bot to a server you don't own, you need to have **Manage Server** or **Administrator** permissions on that Discord server."
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@purple}
		reply to event-message with last made embed with event-bot with rows {_row}

discord command servers:
	prefixes: {@p}
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		set {_gl} to "%guilds of event-bot%"
		replace all ", " and "and" in {_gl} with "|"
		set {_g::*} to split {_gl} at "|"
		make embed:
			set author of the embed to "Servers"
			set author icon of the embed to {@icon}
			set title of the embed to "My servers"
			set description of the embed to "%{_g::*}%"
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@purple}
		reply to event-message with last made embed with event-bot
		delete {_gl::*}
		delete {_g::*}

on bot join guild:
	set {stayinchannel::%discord id of event-guild%} to false
	set {accpetedTOS::%discord id of event-guild%} to false
	set {readRules::%discord id of event-guild%} to false
	set {_b} to self member of event-bot in event-guild
	loop text channels of event-guild:
		if {_b} has permission (view channel, message send) in {_b}:
			set {_c} to loop-textchannel
			stop loop
	if {_c} is not set:
		send "Cannot found an channel to send the message in %event-guild%" to console
	set {_size} to size of guilds of bot named {@bot}
	set presence of bot named {@bot} to playing "music in %{_size}% servers! | {@p}help"
	set {_row} to new buttons row
	add new button "onjoin_readrules" with style primary with content "Read Rules" with emoji "scroll" to buttons of {_row}
	add new button "onjoin_acceptrules" with style success with content "Accept Rules" with emoji "white_check_mark" to buttons of {_row}
	make embed:
		set author of the embed to "Joined server"
		set author icon of the embed to {@icon}
		set title of the embed to "I joined the party!"
		set description of the embed to "Yay! I have arrived fresh to your Discord server, **%event-guild%**! Here are tips to get you started:%nl%To setup your server, use `$setup`. This is required to use some functions of the bot.%nl%To play music in your VC, use `$play (song name|youtube url)`, we don't support spotify and soundcloud yet.%nl%For more commands, use `$help`.%nl%%nl%You must read DisTune's rules before using the bot. Click **Read Rules** to read the rules, and once you're done, click **Accept Rules** to use the bot."
		set footer of the embed to {@footerText}
		set footer icon of the embed to {@icon}
		set color of the embed to {@purple}
	send last made embed to {_c} with rows {_row} with bot named {@bot}

discord command {@p}varreset:
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		set {stayinchannel::%discord id of event-guild%} to false
		set {accpetedTOS::%discord id of event-guild%} to false
		set {readRules::%discord id of event-guild%} to false
		set {setup::%discord id of event-guild%} to false
		delete {setup.User::%discord id of event-guild%}
		reply to event-message with "All variables for guild **%event-guild%** [%discord id of event-guild%] has been reset." with event-bot
		stop

discord command reset:
	prefixes: {@p}
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		if event-member has permission (manage server):
			set {stayinchannel::%discord id of event-guild%} to false
			set {accpetedTOS::%discord id of event-guild%} to false
			set {readRules::%discord id of event-guild%} to false
			set {setup::%discord id of event-guild%} to false
			delete {setup.User::%discord id of event-guild%}
			set {_row} to new buttons row
			add new button "onjoin_readrules" with style primary with content "Read Rules" with emoji "scroll" to buttons of {_row}
			add new button "onjoin_acceptrules" with style success with content "Accept Rules" with emoji "white_check_mark" to buttons of {_row}
			make embed:
				set author of the embed to "Joined server"
				set author icon of the embed to {@icon}
				set title of the embed to "I joined the party!"
				set description of the embed to "Yay! I have arrived fresh to your Discord server, **%event-guild%**! Here are tips to get you started:%nl%To setup your server, use `$setup`. This is required to use some functions of the bot.%nl%To play music in your VC, use `$play (song name|youtube url)`, we don't support spotify and soundcloud yet.%nl%For more commands, use `$help`.%nl%%nl%You must read DisTune's rules before using the bot. Click **Read Rules** to read the rules, and once you're done, click **Accept Rules** to use the bot."
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@purple}
			reply to event-message with last made embed with event-bot with rows {_row} 

		else:
			reply to event-message with "You need **manage server** to reset settings!"
			stop

on bot leave guild:
	set {_size} to size of guilds of bot named {@bot}
	set presence of bot named {@bot} to playing "music in %{_size}% servers! | {@p}help"

discord command {@p}syncvars:
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		if discord id of event-guild = "919252887694110740":
			if discord id of event-member = "702044939520835587":
				loop all guilds of event-bot:
					set {stayinchannel::%discord id of loop-value%} to false
				reply to event-message using "I have synced the stayinchannel variable to servers I am in! **(%{_guilds::*}%)**" with event-bot
			
			else:
				reply to event-message using "You are not Cerial!" with event-bot
		
		else:
			reply to event-message using "You need to be in the dev server to use this!" with event-bot

discord command settings [<text>] [<text>]:
	prefixes: {@p}
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		if arg 1 = "stayinchannel" or "stay":
			if arg 2 is not set:
				reply to event-message using "The current setting for `stayinchannel` is **%{stayinchannel::%discord id of event-guild%}%**." with event-bot
				stop
			
			if arg 2 = "true":
				set {stayinchannel::%discord id of event-guild%} to true
				make embed:
					set author of the embed to "Settings"
					set author icon of the embed to {@icon}
					set title of the embed to "Set settings! <a:distune_checkmark:924010501892083732>"
					set description of the embed to "I have set the setting `stayinchannel` to true! This means when a song ends, I will still stay in the same VC."
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@green}
				reply to event-message using last made embed with event-bot
			
			if arg 2 = "false":
				set {stayinchannel::%discord id of event-guild%} to false
				make embed:
					set author of the embed to "Settings"
					set author icon of the embed to {@icon}
					set title of the embed to "Set settings! <a:distune_checkmark:924010501892083732>"
					set description of the embed to "I have set the setting `stayinchannel` to false! This means after 30 seconds, I will disconnect from the VC."
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@green}
				reply to event-message using last made embed with event-bot
			
			if arg 2 is not "true" or "false":
				make embed:
					set author of the embed to "Settings"
					set author icon of the embed to {@icon}
					set title of the embed to "Error! <a:distune_tnt:924009888059899945>"
					set description of the embed to "I expected **true** or **false** from this setting, but got **%arg 2%** instead.%nl%```applescript%nl%{@p}settings stayinchannel <true|false>%nl%```"
					set footer of the embed to {@footerText}
					set footer icon of the embed to {@icon}
					set color of the embed to {@red}
				reply to event-message using last made embed with event-bot

discord command help:
	prefixes: {@p}
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		set {_row} to new buttons row
		add new button "help_music" with style primary with content "Music Commands" with emoji "distune_music" to buttons of {_row}
		add new button "help_other" with style primary with content "Other Commands" with emoji "flushed" to buttons of {_row}
		make embed:
			set author of the embed to "Help"
			set author icon of the embed to {@icon}
			set title of the embed to "Help Menu"
			set description of the embed to "Welcome to the help menu!%nl%Select a category right now"
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@purple}
		reply to event-message using last made embed with event-bot with rows {_row} and store it in {helpEmbed::%discord id of event-member%}
		set {helpSession::%discord id of event-member%} to random 6 char string from charset `a-zA-Z0-9`

on button click:
	if {helpSession::%discord id of event-member%} is set:
		set {_button} to event-button
		if {_button} = "help_music":
			loop all discord command:
				if discord command category of loop-value = "music":
					add "**{@p}%loop-value%** - %description of loop-value%" to {_e::*}
			set {_brehmoment::*} to join {_e::*} with nl
			make embed:
				set author of the embed to "Help"
				set author icon of the embed to {@icon}
				set title of the embed to "Help - Music"
				set description of the embed to "These are the commands in the **Music** category.%nl%%nl%%{_brehmoment::*}%"
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@purple}
			reply with hidden last made embed
		
		if {_button} = "help_other":
			loop all discord command:
				if discord command category of loop-value = "other":
					add "**{@p}%loop-value%** - %description of loop-value%" to {_e::*}
			set {_brehmoment::*} to join {_e::*} with nl
			make embed:
				set author of the embed to "Help"
				set author icon of the embed to {@icon}
				set title of the embed to "Help - Music"
				set description of the embed to "These are the commands in the **Other** category.%nl%%nl%%{_brehmoment::*}%"
				set footer of the embed to {@footerText}
				set footer icon of the embed to {@icon}
				set color of the embed to {@purple}
			reply with hidden last made embed
		
		else:
			stop
	
	else:
		make embed:
			set author of the embed to "Help"
			set author icon of the embed to {@icon}
			set title of the embed to "Not your help session!"
			set description of the embed to "To make a help session, simply type `{@p}help!`"
			set footer of the embed to {@footerText}
			set footer icon of the embed to {@icon}
			set color of the embed to {@red}
		reply with hidden last made embed
		

discord command meme:
	prefixes: {@p}
	trigger:
		#reply to event-message with "NOTE: At <t:1644501600>, ALL DisTune commands prefixed with `{@p}` will be removed, and will be replaced with slash commands instead. This is to cooperate with Discord enforcing slash commands in April. Thank you for understanding." with event-bot
		#if agreedToTOS(event-guild) = true:
		send a request to "https://meme-api.herokuapp.com/gimme"
		set {_input} to the last http response
		set {_body} to {_input}'s body
		copy json {_body} to {_output::*}
		# The text below is debug mode. ONLY USE IT WHEN NEEDED.
