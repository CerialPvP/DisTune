				if arg 1 contains "music.youtube.com":
					set {_play} to arg 1
					replace all "music." in {_play} with ""
					search in youtube for {_play} and store it in {_r::*}
					if {_r::*} is not set:
						make embed:
							set author of the embed to "Play"
							set author icon of the embed to {@icon}
							set title of the embed to "Song unlisted / private!"
							set description of the embed to "The link you have gave me is either unlisted or private."
							set color of the embed to {@red}
						reply with hidden last made embed with event-bot
						stop
					set {_thumb} to {_play}
					replace all "https://youtube.com/watch?v=" and "&feature=" in {_thumb} with ""
					set {_vc} to voice channel of event-member
					connect event-bot to {_vc}
					#play "https://cdn.discordapp.com/attachments/937063478324236358/937063501925609503/distune_songcountdown.mp3" in event-guild with bot {@bot}
					wait 0.1 seconds
					play {_r::1} in event-guild with event-bot
					make embed:
						set author of the embed to "Play"
						set author icon of the embed to {@icon}
						set title of the embed to "Playing music"
						set description of the embed to "I am now playing **%{_r::1}%**! Keep vibin'!"
						add field named "Track Duration" with value "%normalized track duration of {_r::1}%" to embed
						set image of the embed to track thumbnail of {_r::1}
						set color of the embed to {@green}
					reply with last made embed with event-bot
					stop
				
